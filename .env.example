# Supabase — copie para .env e preencha com os dados do seu projeto
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Roteamento (opcional — use pelo menos uma para rota no mapa)
# Google Maps: trânsito em tempo real (https://console.cloud.google.com)
VITE_GOOGLE_MAPS_API_KEY=

# OpenRouteService: rota mais curta sem trânsito (https://openrouteservice.org)
VITE_ORS_API_KEY=
